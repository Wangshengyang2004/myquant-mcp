# MyQuant Financial Agent MCP Server Configuration

# GM API Token (required)
# Get your token from 掘金量化 platform: User -> Key Management
GM_TOKEN=your_gm_token_here

# GM API Service Address (required when running against local GUI or gateway)
GM_SERV_ADDR=127.0.0.1:7001

# Authentication Configuration
# Whether to require authentication token for trading operations
REQUIRE_AUTH_TOKEN=true

# Authentication token for MCP trading operations
# Generate a secure random token: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_AUTH_TOKEN=your_secure_auth_token_here

# Developer password for sensitive tools (e.g. exec_code)
DEV_PASSWORD=please_change_me

# Trading Safety Configuration
# Enable/disable trading operations (set to false for read-only mode)
TRADING_ENABLED=false

# Maximum order value in CNY (default: 100,000)
MAX_ORDER_VALUE=100000

# Maximum position as percentage of portfolio (default: 0.1 = 10%)
MAX_POSITION_PERCENT=0.1

# Zhipu AI (GLM-4) API Configuration - Anthropic Compatible
# Get your key from: https://open.bigmodel.cn/
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic

# GLM Model Mappings for Claude Code SDK
ANTHROPIC_DEFAULT_OPUS_MODEL=GLM-4.7
ANTHROPIC_DEFAULT_SONNET_MODEL=GLM-4.7
ANTHROPIC_DEFAULT_HAIKU_MODEL=GLM-4.5-Air

# Disable non-essential traffic for GLM compatibility
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
