# MyQuant MCP Server Configuration

# GM API Token (required)
# Get your token from 掘金量化 platform: User -> Key Management
GM_TOKEN=your_gm_token_here

# GM API Service Address
# Leave empty when the 掘金量化 GUI is running on the same machine.
# Set to host:port when the GUI runs on another machine, for example 192.168.1.10:7001.
GM_SERV_ADDR=

# Authentication Configuration
# Whether to require authentication token for account and trading operations
REQUIRE_AUTH_TOKEN=true

# Authentication token for protected MCP operations.
# Generate a secure random token: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave blank only if REQUIRE_AUTH_TOKEN=false.
# Example: MCP_AUTH_TOKEN=replace_with_a_long_random_value
MCP_AUTH_TOKEN=

# Trading Safety Configuration
# Enable/disable trading operations (set to false for read-only mode)
TRADING_ENABLED=false

# Default account id for account/trading queries when required by the GM terminal
GM_ACCOUNT_ID=

# Maximum order value in CNY (default: 100,000)
MAX_ORDER_VALUE=100000

# Maximum position as percentage of portfolio (default: 0.1 = 10%)
MAX_POSITION_PERCENT=0.1

# Server host/port
HOST=0.0.0.0
PORT=8001

# Audit logging threshold in milliseconds
SLOW_THRESHOLD_MS=100

